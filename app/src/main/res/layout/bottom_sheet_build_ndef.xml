<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/build_ndef_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/build_ndef_type"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_ndef_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/build_ndef_value"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_ndef_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/build_ndef_value_hint"
            android:inputType="textMultiLine"
            android:minLines="1"
            android:maxLines="4"
            android:importantForAutofill="no" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_add_ndef_record"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="112dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/bg_button_text_ripple"
                android:text="@string/build_ndef_add_record"
                android:textSize="15sp"
                android:textColor="#DCE4FF"
                android:stateListAnimator="@null"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_clear_ndef_records"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="96dp"
                android:layout_marginStart="12dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/bg_button_text_ripple"
                android:text="@string/build_ndef_clear_records"
                android:textSize="16sp"
                android:textColor="#DCE4FF"
                android:stateListAnimator="@null"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_ndef_record_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="18dp" />

        <TextView
            android:id="@+id/tv_ndef_record_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="72dp"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:text="@string/build_ndef_empty_records"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:background="?android:attr/colorBackground" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_ndef_cancel"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="96dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/bg_button_text_ripple"
                android:text="@android:string/cancel"
                android:textSize="16sp"
                android:textColor="#DCE4FF"
                android:stateListAnimator="@null"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_ndef_ok"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="96dp"
                android:layout_marginStart="12dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/bg_button_text_ripple"
                android:text="@string/build_ndef_generate"
                android:textSize="16sp"
                android:textColor="#DCE4FF"
                android:stateListAnimator="@null"
                android:textAllCaps="false" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>